{
  "name": "@documentation/customize",
  "private": true,
  "version": "0.0.9",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "echo \"skip sync for library\"",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run",
    "check": "pnpm run svelte-check && pnpm run lint",
    "check:fix": "pnpm run svelte-check && eslint . && pnpm run format"
  },
  "homepage": "https://flightlesslabs.github.io/dodo-ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flightlesslabs/dodo-ui.git"
  },
  "dependencies": {
    "@flightlesslabs/dodo-core-attributes": "workspace:*",
    "@flightlesslabs/dodo-ui": "workspace:*",
    "@flightlesslabs/dodo-ui-bits": "workspace:*",
    "@flightlesslabs/dodo-ui-date": "workspace:*",
    "@flightlesslabs/dodo-ui-numeric": "workspace:*",
    "@iconify/svelte": "^5.2.2",
    "@internationalized/date": "^3.12.2",
    "bits-ui": "^2.18.1",
    "svelte": "^5.56.4",
    "svelte-number-format": "^2.0.0"
  }
