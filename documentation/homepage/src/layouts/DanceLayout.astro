---
import '@flightlesslabs/dodo-ui/styles/global/index.scss';
import '@flightlesslabs/dodo-ui/styles/components.scss';
// Addon (dodo-ui-bits)
import '@flightlesslabs/dodo-ui-bits/styles/main.css';
import '@flightlesslabs/dodo-ui-date/styles/main.scss';

import TheHeader from '../components/TheHeader/TheHeader.astro';
import BaseLayoutContainer from './BaseLayoutContainer/BaseLayoutContainer.astro';
---

<BaseLayoutContainer>
  <div class="backdrop">
    <TheHeader variant="text" />
    <main>
      <slot />
    </main>
  </div>
</BaseLayoutContainer>

<style lang="scss">
  @keyframes fluidFlow {
    0% {
      background-position: 50% 0%; /* Starts at the top (coral) */
    }
    100% {
      background-position: 50% 100%; /* Glides to the bottom (peach) */
    }
  }

  .backdrop {
    height: 100vh;
    overflow: hidden;
    background-color: hsl(12deg 71% 63%);
    /* Your exact gradient */
    background-image: linear-gradient(
      180deg,
      hsl(12deg 71% 63%) 0%,
      hsl(13deg 70% 63%) 18%,
      hsl(14deg 69% 63%) 33%,
      hsl(15deg 68% 63%) 47%,
      hsl(17deg 67% 64%) 58%,
      hsl(18deg 66% 64%) 67%,
      hsl(19deg 65% 64%) 75%,
      hsl(20deg 64% 64%) 80%,
      hsl(21deg 62% 65%) 85%,
      hsl(22deg 61% 65%) 89%,
      hsl(23deg 60% 66%) 92%,
      hsl(24deg 58% 66%) 94%,
      hsl(25deg 57% 67%) 96%,
      hsl(25deg 55% 67%) 97%,
      hsl(26deg 54% 68%) 98%,
      hsl(27deg 52% 68%) 99%,
      hsl(28deg 50% 69%) 100%,
      hsl(29deg 48% 70%) 100%
    );

    /* Make it 200% taller than the container */
    background-size: 100% 200%;

    /* Animate it smoothly back and forth */
    animation: fluidFlow 7s ease-in-out infinite alternate;
  }

  main {
    height: calc(100vh - var(--TheHeader-height));
    overflow-y: auto;
    position: relative;
  }
</style>
