---
import DanceLayout from '../layouts/DanceLayout.astro';
import Identity from '../components/Home/Identity.astro';
import Showcase from '../components/Home/Showcase/Showcase.astro';
---

<DanceLayout>
  <div class="page">
    <div class="top">
      <Identity />
    </div>

    <div class="bottom">
      <Showcase />
    </div>
  </div>
</DanceLayout>

<style lang="scss">
  .page {
    width: 100%;
    display: flex;
    align-items: center;
    padding: calc(var(--dodo-ui-space) * 2);
    position: relative;
    flex-direction: column;
    min-height: 100%;
    justify-content: space-between;
  }

  .top {
    padding-top: 20px;

    @media (min-width: 1600px) {
      padding-top: 30px;
    }
  }

  .bottom {
    position: relative;
    bottom: calc(var(--dodo-ui-space) * -2);
    width: 100%;
    height: 240px;
    overflow: hidden;
    margin-top: calc(var(--dodo-ui-space) * 2);
  }
</style>
