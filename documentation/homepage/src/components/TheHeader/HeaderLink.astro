---
interface Props {
  href: string;
  target?: string;
  class?: string;
}

const { href = 'solid', class: className = '', target } = Astro.props as Props;
---

<a href={href} target={target} class={['HeaderLink', className].filter(Boolean).join(' ')}>
  <slot />
</a>

<style lang="scss">
  .HeaderLink {
    margin: 0 8px;
    display: inline-flex;
    color: inherit;
    cursor: pointer;
    font-size: 1.1rem;
    font-weight: 500;
    text-decoration: none;
    padding: 4px;
    transition:
      font-weight 70ms,
      color 70ms;

    &:hover {
      font-weight: 600;
    }

    @media (min-width: 800px) {
      margin: 0 12px;
      font-size: 1.5rem;
    }
  }
</style>
