{
  "name": "dodo-ui",
  "version": "0.0.0",
  "scripts": {
    "dev": "pnpm --filter @documentation/docs dev",
    "build": "pnpm -r build",
    "build:documentation": "pnpm --filter @documentation/* build",
    "build:packages": "pnpm --filter @flightlesslabs/* build",
    "test": "pnpm -r test",
    "check": "pnpm -r check",
    "check:fix": "pnpm -r check:fix"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/compat": "^2.0.4",
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/node": "^24",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-storybook": "^10.3.5",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "publint": "^0.3.18",
    "sass": "^1.99.0",
    "vite": "^8.0.7",
    "vitest": "^4.1.3"
  }
}
